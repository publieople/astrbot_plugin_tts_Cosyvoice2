{
    "if_remove_think_tag": {
        "description": "是否去除<think></think>",
        "type": "bool",
        "hint": "因为deepseek-r1模型及其衍生模型会以<think>.....</think>的形式输出思考过程，会影响语音合成",
        "obvious_hint": true
    },
    "if_reduce_parenthesis": {
        "description": "是否提醒llm减少括号中内容生成",
        "type": "bool",
        "hint": "有些人格设置会影响该设置生效，请酌情使用"
    },
    "if_remove_emoji": {
        "description": "是否去除句子里的表情(emoji)",
        "type": "bool"
    },
    "if_fp16": {
        "description": "是否使用fp16精度减少占用",
        "type": "bool",
        "hint": "降低精度可能会影响生成质量，酌情开启"
    },
    "if_preload": {
        "description": "是否预加载模型",
        "type": "bool",
        "hint": "建议开启，使function_call等更快响应",
        "default": true
    },
    "generate_method": {
        "description": "生成模式选择",
        "type": "string",
        "options": ["zero_shot","instruct2"],
        "hint": "zero_shot需要提供源语音中的文字内容，instruct2则不需要",
        "default": "instruct2"
    },
    "misc":{
        "description": "音源配置",
        "type": "object",
        "items": {
            "source_prompt":{
                "description": "源音频文件（sounds目录下）",
                "type": "string",
                "hint": "要克隆的角色音频文件名",
                "default": ""
            },
            "zero_shot_text":{
                "description": "zero_shot文本",
                "type": "string",
                "hint": "zero_shot模式下源音频中的文字内容，越准确越好。instruct2模式不需要",
                "obvious_hint": true,
                "default": ""
            },
            "instruct_speech_dialect":{
                "description": "合成语音语言/方言",
                "type": "string",
                "hint": "用什么话说出来：普通话、四川话、广东话、日语等",
                "obvious_hint": true,
                "default": "普通话"
            }
        }
    },
    "serve_config":{
        "description": "服务器设置",
        "type": "object",
        "items": {
            "server_ip":{
                "description": "CoyVoice2 服务地址",
                "type": "string",
                "hint": "本机使用 127.0.0.1",
                "default": "127.0.0.1"
            },
            "if_seperate_serve": {
                "description": "使用独立部署的 CosyVoice2 服务",
                "type": "bool",
                "hint": "开启后插件不启动本地模型，通过 API 连接外部 CosyVoice2 服务",
                "default": true
            }
        }
    }
}
